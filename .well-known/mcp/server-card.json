{
  "serverInfo": {
    "name": "date-aware-claude",
    "version": "1.1.0"
  },
  "tools": [
    {
      "name": "get_today",
      "description": "Return today's date, current time, and weekday in the resolved timezone.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "IANA timezone name, e.g. 'America/New_York' or 'Asia/Tokyo'. Omit to use the server's configured default timezone."
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "time": { "type": "string" },
          "datetime": { "type": "string" },
          "weekday": { "type": "string" },
          "timezone": { "type": "string" }
        },
        "required": ["date", "time", "datetime", "weekday", "timezone"]
      }
    },
    {
      "name": "convert_timezone",
      "description": "Convert a datetime from one timezone to another.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "datetime_str": {
            "type": "string",
            "description": "Datetime to convert. Either 'YYYY-MM-DD HH:MM:SS' (naive, requires from_timezone) or ISO 8601 with offset e.g. '2026-04-17T09:00:00-04:00'."
          },
          "to_timezone": {
            "type": "string",
            "description": "Target IANA timezone name, e.g. 'Europe/London' or 'Asia/Shanghai'."
          },
          "from_timezone": {
            "type": "string",
            "description": "Source IANA timezone name. Required when datetime_str has no UTC offset. Ignored when datetime_str includes an offset."
          }
        },
        "required": ["datetime_str", "to_timezone"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "original": { "type": "string" },
          "original_timezone": { "type": "string" },
          "converted": { "type": "string" },
          "converted_timezone": { "type": "string" },
          "weekday": { "type": "string" }
        },
        "required": ["original", "original_timezone", "converted", "converted_timezone", "weekday"]
      }
    },
    {
      "name": "get_business_days",
      "description": "Count business days (Monday-Friday) between two dates. Counts weekdays only; does NOT skip public holidays. Handles reversed ranges by swapping internally while echoing input dates unswapped.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "date_from": {
            "type": "string",
            "description": "Start date in YYYY-MM-DD format."
          },
          "date_to": {
            "type": "string",
            "description": "End date in YYYY-MM-DD format."
          },
          "inclusive": {
            "type": "boolean",
            "description": "If true, both endpoints count. If false, the half-open range [date_from, date_to) is used. Default true (matches Excel NETWORKDAYS)."
          }
        },
        "required": ["date_from", "date_to"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "date_from": { "type": "string" },
          "date_to": { "type": "string" },
          "business_days": { "type": "integer" },
          "weekend_days": { "type": "integer" },
          "total_days": { "type": "integer" }
        },
        "required": ["date_from", "date_to", "business_days", "weekend_days", "total_days"]
      }
    }
  ],
  "resources": [],
  "prompts": []
}
